    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_Antrag" targetRef="Task_DatenValidieren" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_DatenValidieren" targetRef="Gateway_DatenGueltig" />
    <bpmn:sequenceFlow id="Flow_03_yes" name="ja" sourceRef="Gateway_DatenGueltig" targetRef="Gateway_00kp3ou">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=datenGueltig = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_03_no" name="nein" sourceRef="Gateway_DatenGueltig" targetRef="Task_AblehnungSenden">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=datenGueltig = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0mnclrb" name="nein" sourceRef="Gateway_00kp3ou" targetRef="Task_ReisekostenKonvertieren">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=travelInsurance.travelData.currency!="EUR"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1mgo24r" sourceRef="Task_ReisekostenKonvertieren" targetRef="Activity_00dcgou" />
    <bpmn:sequenceFlow id="Flow_07e0n47" sourceRef="Gateway_0jd6c4w" targetRef="decision-0vu1ysr" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="decision-0vu1ysr" targetRef="Gateway_AntragAblehnen" />
    <bpmn:sequenceFlow id="Flow_06_no" name="ja" sourceRef="Gateway_AntragAblehnen" targetRef="Task_TelefonPruefen">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=Grund = "Gut"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13wvw8j" name="nein" sourceRef="Gateway_AntragAblehnen" targetRef="Activity_0yxmgw6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=Grund != "Gut"</bpmn:conditionExpression>
