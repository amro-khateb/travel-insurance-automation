      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=some id in reisewarnungResponse.body.response.contentList satisfies
      lower case (get value(reisewarnungResponse.body.response, id).countryName) = lower case (string(travelInsurance.travelData.destination))
      and
      (
        get value(reisewarnungResponse.body.response, id).warning = true
        or
        get value(reisewarnungResponse.body.response, id).partialWarning = true
